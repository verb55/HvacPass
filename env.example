# Supabase Configuration
# ===========================================
# Skopiuj ten plik do .env.local i wypełnij wartości

# URL projektu Supabase
# Znajdziesz w: Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=twoj_url_projektu

# Klucz anonimowy (public)
# Znajdziesz w: Supabase Dashboard > Settings > API > Project API keys > anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj_klucz_anonimowy

# ===========================================
# Opcjonalne (dla produkcji)
# ===========================================

# URL aplikacji (dla OAuth redirects)
# NEXT_PUBLIC_APP_URL=http://localhost:3000